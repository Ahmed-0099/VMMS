generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  ENDED
}

enum MaintenanceScheduleStatus {
  ACTIVE
  DUE
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  PENDING_PARTS
  COMPLETED
  CLOSED
}

enum FaultUrgency {
  LOW
  MEDIUM
  HIGH
}

enum FaultReportStatus {
  NEW
  REVIEWED
  CONVERTED_TO_WORK_ORDER
  CLOSED
}

enum ComplianceDocumentStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  passwordHash        String        @map("password_hash")
  status              UserStatus    @default(ACTIVE)
  roleId              String        @map("role_id")
  role                Role          @relation(fields: [roleId], references: [id])
  technicianOrders    WorkOrder[]   @relation("TechnicianWorkOrders")
  createdFaultReports FaultReport[] @relation("FaultReporter")
  driverProfile       Driver?
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Vehicle {
  id                   String                @id @default(cuid())
  registrationNumber   String                @unique @map("registration_number")
  make                 String
  model                String
  year                 Int?
  vin                  String?               @unique
  fuelType             String                @map("fuel_type")
  category             String?
  currentOdometer      Int?                  @map("current_odometer")
  status               VehicleStatus         @default(ACTIVE)
  assignments          VehicleAssignment[]
  maintenanceSchedules MaintenanceSchedule[]
  workOrders           WorkOrder[]
  faultReports         FaultReport[]
  fuelLogs             FuelLog[]
  complianceDocuments  ComplianceDocument[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@map("vehicles")
}

model Driver {
  id            String              @id @default(cuid())
  userId        String?             @unique @map("user_id")
  user          User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName      String              @map("full_name")
  cnic          String?             @unique
  licenseNumber String              @unique @map("license_number")
  licenseExpiry DateTime            @map("license_expiry")
  phone         String?
  address       String?
  status        DriverStatus        @default(ACTIVE)
  assignments   VehicleAssignment[]
  faultReports  FaultReport[]
  fuelLogs      FuelLog[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@map("drivers")
}

model VehicleAssignment {
  id        String           @id @default(cuid())
  vehicleId String           @map("vehicle_id")
  driverId  String           @map("driver_id")
  startDate DateTime         @map("start_date")
  endDate   DateTime?        @map("end_date")
  status    AssignmentStatus @default(ACTIVE)
  vehicle   Vehicle          @relation(fields: [vehicleId], references: [id])
  driver    Driver           @relation(fields: [driverId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([vehicleId, status])
  @@index([driverId, status])
  @@map("vehicle_assignments")
}

model MaintenanceSchedule {
  id              String                    @id @default(cuid())
  vehicleId       String                    @map("vehicle_id")
  serviceType     String                    @map("service_type")
  nextDueDate     DateTime?                 @map("next_due_date")
  nextDueOdometer Int?                      @map("next_due_odometer")
  notes           String?
  status          MaintenanceScheduleStatus @default(ACTIVE)
  vehicle         Vehicle                   @relation(fields: [vehicleId], references: [id])
  workOrders      WorkOrder[]
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_schedules")
}

model WorkOrder {
  id                    String               @id @default(cuid())
  vehicleId             String               @map("vehicle_id")
  technicianId          String?              @map("technician_id")
  maintenanceScheduleId String?              @map("maintenance_schedule_id")
  priority              WorkOrderPriority    @default(MEDIUM)
  status                WorkOrderStatus      @default(OPEN)
  serviceType           String               @map("service_type")
  description           String
  dueDate               DateTime?            @map("due_date")
  laborHours            Float?               @map("labor_hours")
  cost                  Float?
  completionNotes       String?              @map("completion_notes")
  vehicle               Vehicle              @relation(fields: [vehicleId], references: [id])
  technician            User?                @relation("TechnicianWorkOrders", fields: [technicianId], references: [id])
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id])
  faultReport           FaultReport?
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([technicianId])
  @@index([status])
  @@map("work_orders")
}

model FaultReport {
  id          String            @id @default(cuid())
  vehicleId   String            @map("vehicle_id")
  driverId    String?           @map("driver_id")
  reporterId  String?           @map("reporter_id")
  workOrderId String?           @unique @map("work_order_id")
  urgency     FaultUrgency      @default(MEDIUM)
  description String
  status      FaultReportStatus @default(NEW)
  photoPath   String?           @map("photo_path")
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  driver      Driver?           @relation(fields: [driverId], references: [id])
  reporter    User?             @relation("FaultReporter", fields: [reporterId], references: [id])
  workOrder   WorkOrder?        @relation(fields: [workOrderId], references: [id])
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([status])
  @@map("fault_reports")
}

model FuelLog {
  id              String   @id @default(cuid())
  vehicleId       String   @map("vehicle_id")
  driverId        String?  @map("driver_id")
  date            DateTime
  fuelType        String   @map("fuel_type")
  quantity        Float
  unitCost        Float    @map("unit_cost")
  totalAmount     Float    @map("total_amount")
  odometerReading Int?     @map("odometer_reading")
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  driver          Driver?  @relation(fields: [driverId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([date])
  @@map("fuel_logs")
}

model ComplianceDocument {
  id             String                   @id @default(cuid())
  vehicleId      String                   @map("vehicle_id")
  documentType   String                   @map("document_type")
  documentNumber String?                  @map("document_number")
  issueDate      DateTime?                @map("issue_date")
  expiryDate     DateTime                 @map("expiry_date")
  filePath       String?                  @map("file_path")
  status         ComplianceDocumentStatus @default(VALID)
  vehicle        Vehicle                  @relation(fields: [vehicleId], references: [id])
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([expiryDate])
  @@index([status])
  @@map("compliance_documents")
}
